function isObject(value) {
  return value && typeof value === 'object' && !Array.isArray(value);
}

function deepMerge(base, incoming) {
  if (!isObject(incoming)) return Array.isArray(base) ? [...base] : { ...base };
  const result = Array.isArray(base) ? [...base] : { ...base };
  Object.entries(incoming).forEach(([key, value]) => {
    if (isObject(value) && isObject(result[key])) {
      result[key] = deepMerge(result[key], value);
    } else {
      result[key] = value;
    }
  });
  return result;
}

function normalizeConfig(config) {
  const merged = deepMerge(DEFAULT_CONFIG, config || {});
  if (!Array.isArray(merged.agents.defaults.model.allowlist)) {
    merged.agents.defaults.model.allowlist = merged.agents.defaults.model.primary ? [merged.agents.defaults.model.primary] : [];
  }
  if (!merged.channels.items || typeof merged.channels.items !== 'object') merged.channels.items = {};
  PLUGINS.forEach((plugin) => {
    if (!merged.plugins[plugin]) merged.plugins[plugin] = { enabled: false };
  });
  SKILLS.forEach((skill) => {
    if (!merged.skills[skill]) merged.skills[skill] = { enabled: false };
  });
  return merged;
}

function cloneConfig(value) {
  if (typeof structuredClone === 'function') return structuredClone(value);
  return JSON.parse(JSON.stringify(value));
}

function getToolStatus(value) {
  if (typeof value === 'boolean') return value;
  if (typeof value === 'string') return value.toLowerCase() === 'true' || value.toLowerCase() === 'installed';
  if (value && typeof value === 'object') {
    if ('installed' in value) return Boolean(value.installed);
    if ('ok' in value) return Boolean(value.ok);
    if ('found' in value) return Boolean(value.found);
  }
  return Boolean(value);
}

function getVersionText(value) {
  if (value == null) return '—';
  if (typeof value === 'string') return value || '—';
  if (typeof value === 'number') return String(value);
  if (typeof value === 'object') return value.version || value.stdout || value.value || value.text || '—';
  return '—';
}

