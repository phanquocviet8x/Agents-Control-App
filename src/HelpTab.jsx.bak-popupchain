      const key = path[path.length - 1];
      const currentArray = Array.isArray(target[key]) ? target[key] : [];
      target[key] = checked ? Array.from(new Set([...currentArray, item])) : currentArray.filter((x) => x !== item);
      return next;
    });
  }

