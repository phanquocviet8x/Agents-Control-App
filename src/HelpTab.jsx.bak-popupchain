        return (
          <div className="form-grid">
            <p>List skills and enable/disable each skill.</p>
            {SKILLS.map((skill) => (
              <label className="radio-option" key={skill}>
                <input type="checkbox" checked={Boolean(config.skills?.[skill]?.enabled)} onChange={(event) => setConfigValue(['skills', skill, 'enabled'], event.target.checked)} />
                <span>{skill}</span>
              </label>
            ))}
          </div>
        );

      case 8:
        return (
          <div className="form-grid">
            <p>Auto-run checks display. These checks summarize gateway + channel readiness before saving.</p>
            <div className="installed-list">
              {healthChecks.map((check) => (
                <div className="installed-item" key={check.label}>
                  <span>{check.label}</span>
                  <span className={check.status === 'Ready' || check.status === 'Enabled' ? 'installed' : 'not-installed'}>{check.status}</span>
                </div>
              ))}
            </div>
          </div>
        );

      case 9:
        return (
          <div className="form-grid">
            <p>Save config and finish setup.</p>
            {savedMessage ? <p className="installed">Configure complete</p> : <p>Click Finish to save config.</p>}
            <div className="installed-list">
              <div className="installed-item"><span>Gateway URL</span><span>http://127.0.0.1:{config.gateway.port || 3000}</span></div>
              <div className="installed-item"><span>Workspace</span><span>{config.agents.defaults.workspace || 'Not set'}</span></div>
              <div className="installed-item"><span>Default model</span><span>{config.agents.defaults.model.primary || 'Not set'}</span></div>
            </div>
          </div>
        );

      default:
        return null;
    }
  }

  return (
    <div className="page-grid">
      <Panel>
        <h2 className="card-title-center">OpenClaw</h2>
        <p>Configure gateway, workspace, model, web tools, daemon, channels, plugins, skills, and health checks.</p>
        <div className="button-row">
          <button className="btn primary" type="button" onClick={openConfigWizard}>Config</button>
        </div>
      </Panel>

      <Panel>
        <h2 className="card-title-center">Ngrok</h2>
        <p>View account information saved in app config.</p>
        <div className="button-row">
          <button className="btn secondary" type="button" onClick={() => setAccountOpen(true)}>View Account</button>
        </div>
      </Panel>

      <Panel>
        <div className="versions-header">
          <h2 className="card-title-center">Installed Apps</h2>
          <button className="btn secondary btn-sm" type="button" onClick={refreshTools}>Refresh</button>
        </div>
        {toolsError && <p className="not-installed">{toolsError}</p>}
        <div className="installed-list">
          {TOOL_NAMES.map((tool) => {
            const installed = getToolStatus(installedApps?.[tool]);
            return (
              <div className="installed-item" key={tool}>
                <span>{tool}</span>
                <span className={installed ? 'installed' : 'not-installed'}>{installed ? 'Installed' : 'Not installed'}</span>
              </div>
            );
          })}
        </div>
      </Panel>

      <Panel>
        <div className="versions-header">
          <h2 className="card-title-center">Versions</h2>
          <button className="btn secondary btn-sm" type="button" onClick={refreshTools}>Refresh</button>
        </div>
        <div className="installed-list">
          {TOOL_NAMES.map((tool) => (
            <div className="installed-item" key={tool}>
              <span>{tool}</span>
              <span>{getVersionText(versions?.[tool])}</span>
            </div>
          ))}
        </div>
      </Panel>

      {wizardOpen && (
        <ModalShell>
          <div className="versions-header">
            <h2>Gateway mode</h2>
            <button className="btn danger btn-sm" type="button" onClick={closeConfigWizard} disabled={savingConfig}>X</button>
          </div>
          <div className="form-grid">
            <p>Where will the Gateway run?</p>
            <button className="btn primary" type="button" onClick={() => selectGatewayMode('local')}>Local (this machine)</button>
            <button className="btn secondary" type="button" onClick={() => selectGatewayMode('remote')}>Remote (info-only)</button>
          </div>
        </ModalShell>
      )}

      {wizardLayout && (
        <div style={{ position: 'fixed', inset: 0, zIndex: 100, display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '24px', background: 'rgba(5,10,20,0.5)', backdropFilter: 'blur(18px)' }}>
          <div style={{ width: 'min(1320px, 96vw)', height: 'min(860px, 94vh)', display: 'grid', gridTemplateColumns: '280px 1fr', overflow: 'hidden', borderRadius: '32px', background: 'transparent' }}>
            <aside style={{ position: 'relative', padding: '18px 16px 16px', backdropFilter: 'blur(20px)', background: 'rgba(255,255,255,0.06)', border: '1px solid rgba(255,255,255,0.15)', boxShadow: '0 24px 70px rgba(0,0,0,.42)', overflow: 'hidden', display: 'flex', flexDirection: 'column', gap: '10px' }}>
              <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: '1px', background: 'linear-gradient(90deg, transparent, rgba(255,255,255,.7), transparent)', pointerEvents: 'none' }} />
              <div style={{ display: 'grid', gap: '7px' }}>
                {steps.map((label, index) => (
                  <button
                    type="button"
                    key={label}
                    onClick={() => { setStep(index); if (index === 9) setHealthChecks(buildHealthChecks(config)); }}
                    style={step === index ? { textAlign: 'left', padding: '10px 14px', borderRadius: '16px', border: '1px solid rgba(153, 246, 228, 0.7)', background: 'linear-gradient(135deg, rgba(34, 211, 238, 0.9), rgba(16, 185, 129, 0.85))', color: '#03131a', fontWeight: 700, boxShadow: '0 10px 30px rgba(20, 184, 166, 0.28), inset 0 1px 0 rgba(255,255,255,0.28)', cursor: 'pointer' } : { textAlign: 'left', padding: '10px 14px', borderRadius: '16px', border: '1px solid rgba(148, 163, 184, 0.2)', background: 'rgba(15, 23, 42, 0.58)', color: 'rgba(226, 232, 240, 0.92)', boxShadow: 'inset 0 1px 0 rgba(255,255,255,0.04)', cursor: 'pointer' }}
                  >
                    {label}
                  </button>
                ))}
              </div>
              <div style={{ marginTop: 'auto', display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '8px' }}>
                <button className="btn secondary" type="button" onClick={() => setStep((current) => Math.max(current - 1, 0))} disabled={step === 0 || loadingConfig || savingConfig}>Top</button>
                <button className="btn secondary" type="button" onClick={() => setStep((current) => Math.min(current + 1, steps.length - 1))} disabled={step === steps.length - 1 || loadingConfig || savingConfig}>Down</button>
              </div>
            </aside>
            <div style={{ display: 'grid', gridTemplateRows: '1fr auto', minWidth: 0, minHeight: 0, gap: '0' }}>
              <main style={{ position: 'relative', padding: '42px 40px 28px', overflow: 'hidden', display: 'flex', alignItems: 'center', justifyContent: 'center', backdropFilter: 'blur(20px)', background: 'rgba(255,255,255,0.04)', border: '1px solid rgba(255,255,255,0.15)', boxShadow: '0 24px 70px rgba(0,0,0,.42)' }}>
                <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: '1px', background: 'linear-gradient(90deg, transparent, rgba(255,255,255,.7), transparent)', pointerEvents: 'none' }} />
                <div style={{ width: '100%', maxWidth: '760px', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', gap: '24px' }}>
                  <h1 style={{ margin: 0, textAlign: 'center', fontSize: 'clamp(28px, 3.2vw, 40px)' }}>{steps[step]}</h1>
                  {configError && <p className="not-installed" style={{ textAlign: 'center' }}>{configError}</p>}
                  <div style={{ width: '100%', maxWidth: '680px', margin: '0 auto' }}>
                    {renderStep()}
                    <div style={{display:'flex',gap:'10px',marginTop:'16px',justifyContent:'center'}}>
                      <button className="btn secondary" type="button" onClick={() => { setConfig(normalizeConfig({})); }}>Reset</button>
                      <button className="btn danger" type="button" onClick={() => { setProviderPopup(null); }}>Cancel</button>
                      <button className="btn primary" type="button" onClick={async () => { await saveConfig(); }}>Apply</button>
                    </div>
                  </div>
                </div>
              </main>
              <div style={{ position: 'relative', display: 'grid', gridTemplateColumns: '1fr auto 1fr', alignItems: 'center', gap: '12px', padding: '18px 24px', backdropFilter: 'blur(20px)', background: 'rgba(255,255,255,0.06)', border: '1px solid rgba(255,255,255,0.15)', boxShadow: '0 24px 70px rgba(0,0,0,.42)' }}>
                <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: '1px', background: 'linear-gradient(90deg, transparent, rgba(255,255,255,.7), transparent)', pointerEvents: 'none' }} />
                <div></div>
                <div style={{color:'#99a9ba',fontSize:'13px',textAlign:'center'}}>{savedMessage || 'No saved sections yet.'}</div>
                <div style={{display:'flex',justifyContent:'flex-end'}}>
                  <button className="btn primary" type="button" onClick={async () => { await saveConfig(); setWizardLayout(false); }} disabled={savingConfig}>Finish</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {providerPopup && (
        <ModalShell>
          <div style={{ minWidth: '420px', maxWidth: '520px' }}>
            <h2 style={{ margin: '0 0 16px', fontSize: '18px' }}>{providerPopup} — auth method</h2>
            {providerAuthStep === 0 && (
              <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                {(PROVIDER_AUTH_METHODS[providerPopup] || ['API key']).map((method) => (
                  <span
                    key={method}
                    onClick={() => {
                      setConfigValue(['agents', 'defaults', 'model', 'authProvider'], providerPopup);
                      setConfigValue(['agents', 'defaults', 'model', 'authMethod'], method);
                      setProviderAuthStep(1);
                    }}
                    style={{ display: 'flex', alignItems: 'center', gap: '10px', cursor: 'pointer', padding: '6px 10px', borderRadius: '6px', color: 'rgba(226,232,240,0.92)' }}
                    onMouseEnter={(e) => { e.currentTarget.style.background = 'rgba(94,234,212,0.12)'; }}
                    onMouseLeave={(e) => { e.currentTarget.style.background = 'transparent'; }}
                  >
                    <span style={{ width: '8px', height: '8px', borderRadius: '50%', border: '2px solid rgba(148,163,184,0.5)', flexShrink: 0 }} />
                    <span>{method}</span>
                  </span>
                ))}
                <span
                  onClick={() => setProviderPopup(null)}
                  style={{ display: 'flex', alignItems: 'center', gap: '10px', cursor: 'pointer', padding: '6px 10px', borderRadius: '6px', color: 'rgba(148,163,184,0.7)' }}
                  onMouseEnter={(e) => { e.currentTarget.style.background = 'rgba(255,255,255,0.06)'; }}
                  onMouseLeave={(e) => { e.currentTarget.style.background = 'transparent'; }}
                >
                  <span style={{ width: '8px', height: '8px', borderRadius: '50%', border: '2px solid rgba(148,163,184,0.5)', flexShrink: 0 }} />
                  <span>Back</span>
                </span>
              </div>
            )}
            {providerAuthStep === 1 && (
              <div className="form-grid">
                <p style={{ margin: '0 0 8px', color: 'rgba(148,163,184,0.8)' }}>Selected: {config.agents.defaults.model.authMethod}</p>
                <label>
                  API Key
                  <input type="password" value={config.agents.defaults.model.apiKey} onChange={(event) => setConfigValue(['agents', 'defaults', 'model', 'apiKey'], event.target.value)} placeholder="Enter API key" />
                </label>
                <label>
                  Default model
                  <input value={config.agents.defaults.model.primary} onChange={(event) => setConfigValue(['agents', 'defaults', 'model', 'primary'], event.target.value)} placeholder="e.g. claude-opus-4.6" />
                </label>
                <div style={{ display: 'flex', gap: '10px', marginTop: '12px' }}>
                  <button className="btn secondary" type="button" onClick={() => setProviderAuthStep(0)}>Back</button>
                  <button className="btn primary" type="button" onClick={() => { setProviderPopup(null); setProviderAuthStep(0); }}>Done</button>
                </div>
              </div>
            )}
          </div>
        </ModalShell>
      )}

      {accountOpen && (
        <ModalShell>
          <div className="versions-header">
            <h2>Ngrok Account</h2>
            <button className="btn danger btn-sm" type="button" onClick={() => setAccountOpen(false)}>X</button>
          </div>
          <div className="form-grid">
            <p>Authtoken, domain, and port are read from the app config. Use API Keys → Ngrok to edit mapping.</p>
            <div className="installed-list">
              <div className="installed-item"><span>Authtoken</span><span>{config?.ngrok?.authtoken ? 'Saved' : 'Not set'}</span></div>
              <div className="installed-item"><span>Domain</span><span>{config?.ngrok?.domain || 'Not set'}</span></div>
              <div className="installed-item"><span>Port</span><span>{config?.ngrok?.port || config.gateway.port || 'Not set'}</span></div>
            </div>
          </div>
          <div className="button-row">
            <button className="btn secondary" type="button" onClick={() => setAccountOpen(false)}>Close</button>
          </div>
        </ModalShell>
      )}
    </div>
  );
}
